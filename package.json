{
  "name": "@git-lfs-hub/e2e",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "tsgo --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "bun run compile && bun run lint && bun run format:check",
    "vitest": "bun run check && bunx --bun vitest",
    "test-local": "GH_PAT=$(gh auth token) RUN_ID=$(date +%s) bun e2e-test",
    "e2e-test": "bun run vitest run --reporter=verbose --reporter=github-actions",
    "e2e-test:watch": "bun run vitest watch"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": "^26.3.0"
  },
  "dependencies": {
    "@git-lfs-hub/lib": "file:../lib"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@typescript/native-preview": "^7.0.0-dev.20260606.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "vitest": "^4.1.8"
  }
}
